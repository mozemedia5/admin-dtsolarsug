rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Products images
    match /products/{productId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Promotions/banners images
    match /promotions/{promotionId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // General uploads (if needed)
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
